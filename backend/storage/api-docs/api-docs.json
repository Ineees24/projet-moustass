                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "role"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "bob@moustass.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "MonMotDePasse1!"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "ADMIN",
                                            "CLIENT"
                                        ],
                                        "example": "CLIENT"
